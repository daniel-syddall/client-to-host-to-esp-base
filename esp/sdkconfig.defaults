# ESP-IDF SDK defaults for this project.
# These are applied on top of the chip defaults when running `idf.py set-target`.
# Override any value here to avoid modifying the generated sdkconfig.

# ── Console ───────────────────────────────────────────────────────────────── #
#
# UART0 is the Pi↔ESP protocol channel (via CH340 USB-UART bridge).
# Disable the IDF console entirely so the IDF startup code does NOT install
# a UART driver on UART0 before app_main() runs.  If it did, our own
# uart_driver_install(UART_NUM_0) call in uart_init() would panic with
# ESP_ERR_INVALID_STATE and the board would stall silently.
#
# Side-effect: ESP_LOGI / ESP_LOGD output is discarded at runtime.
# To debug: temporarily set CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y and
# connect the native USB port to a host running:  idf.py monitor -p /dev/ttyACM0
#
CONFIG_ESP_CONSOLE_NONE=y

# ── FreeRTOS ──────────────────────────────────────────────────────────────── #

# 1 kHz tick rate (1 ms resolution).
CONFIG_FREERTOS_HZ=1000

# ── Logging ───────────────────────────────────────────────────────────────── #

# Default log level: INFO in production, DEBUG during development.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
# CONFIG_LOG_DEFAULT_LEVEL_DEBUG=y

# ── Flash size ────────────────────────────────────────────────────────────── #

CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# ── Watchdog ──────────────────────────────────────────────────────────────── #

# Disable the task watchdog on the idle task so long-running serial reads
# don't trigger a reset during development.
CONFIG_ESP_TASK_WDT_EN=n
